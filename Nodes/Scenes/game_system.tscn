[sub_resource type="GDScript" id="GDScript_fuapw"]
script/source = "extends Room_Script
#-------------------------------------------------------------------------------
@export_category(\"Ally 0\")
@export var ally_0: Interactable_Script
@export var ally_0_character: Character_Node
@export var ally_0_fighter_resouce: Fighter_Resource
@export var ally_0_fighter_prefab: PackedScene
#-------------------------------------------------------------------------------
@export_category(\"Ally 1\")
@export var ally_1: Interactable_Script
@export var ally_1_character: Character_Node
@export var ally_1_fighter_resouce: Fighter_Resource
@export var ally_1_fighter_prefab: PackedScene
#-------------------------------------------------------------------------------
@export_category(\"Ally 2\")
@export var ally_2: Interactable_Script
@export var ally_2_character: Character_Node
@export var ally_2_fighter_resouce: Fighter_Resource
@export var ally_2_fighter_prefab: PackedScene
#-------------------------------------------------------------------------------
@export_category(\"NPC 3\")
@export var npc_3: Interactable_Script
@export var npc_3_character_resource: Character_Resource
@export var npc_3_item_consumable_array: Array[Action_Serializable]
@export var npc_3_item_equip_array: Array[Equip_Serializable]
@export var npc_3_item_key_array: Array[Key_Serializable]
#-------------------------------------------------------------------------------
@export_category(\"NPC 4\")
@export var npc_4: Interactable_Script
@export var npc_4_fighter_array: Array[Fighter_Node]
#-------------------------------------------------------------------------------
func Set_Room():
	Set_NPC_1(ally_0, ally_0_character, ally_0_fighter_resouce, ally_0_fighter_prefab)
	Set_NPC_1(ally_1, ally_1_character, ally_1_fighter_resouce, ally_1_fighter_prefab)
	Set_NPC_1(ally_2, ally_2_character, ally_2_fighter_resouce, ally_2_fighter_prefab)
	npc_3.interactable_by_action = func(): NPC_3_Talk()
	npc_4.interactable_by_action = func(): NPC_4_Talk()
#-------------------------------------------------------------------------------
func Set_NPC_1(_imteractable_script:Interactable_Script, _character_node:Character_Node, _fighter_resource:Fighter_Resource, _fighter_prefab:PackedScene):
	var _index: int = singleton.game_system.Get_Fighter_Node_Index(_fighter_resource)
	#-------------------------------------------------------------------------------
	if(_index < 0):
		_character_node.modulate.a = 1.0
	#-------------------------------------------------------------------------------
	else:
		_character_node.modulate.a = 105.0/255.0
	#-------------------------------------------------------------------------------
	_imteractable_script.interactable_by_action = func(): NPC_1_Talk(_imteractable_script, _character_node, _fighter_resource, _fighter_prefab)
#-------------------------------------------------------------------------------
func NPC_1_Talk(_imteractable_script:Interactable_Script, _character_node:Character_Node, _fighter_resource:Fighter_Resource, _fighter_prefab:PackedScene):
	_imteractable_script.collider.disabled = true
	#-------------------------------------------------------------------------------
	singleton.game_system.Stop_Moving()
	singleton.game_system.Dialogue_Open()
	#-------------------------------------------------------------------------------
	var _player_1_character_resource: Character_Resource = singleton.game_system.ally_node_array[0].character_node.character_resource
	#-------------------------------------------------------------------------------
	var _index: int = singleton.game_system.Get_Fighter_Node_Index(_fighter_resource)
	#-------------------------------------------------------------------------------
	if(_index < 0):
		await singleton.game_system.Dialogue_with_Face_0(_character_node.character_resource, \"* Querés que te acompañe?\")
		singleton.game_system.Open_Dialogue_Options([\"Si\", \"No\"])
		await singleton.game_system.next_signal
		#-------------------------------------------------------------------------------
		match(singleton.game_system.dialogue_option_index):
			0:
				singleton.game_system.Close_Dialogue_Options()
				await singleton.game_system.Dialogue_with_Face(_character_node.character_resource, \"* Ok, voy a ir con vos.\")
				var _fighter_ally_1: Fighter_Node = _fighter_prefab.instantiate() as Fighter_Node
				singleton.game_system.player_characterbody2d.add_child(_fighter_ally_1)
				singleton.game_system.ally_node_array.append(_fighter_ally_1)
				singleton.game_system.Set_Fighter_0()
				_character_node.modulate.a = 105.0/255.0
			#-------------------------------------------------------------------------------
			1:
				singleton.game_system.Close_Dialogue_Options()
				await singleton.game_system.Dialogue_with_Face(_character_node.character_resource, \"* Ok, voy a estar acá si me necesitas.\")
			#-------------------------------------------------------------------------------
		#-------------------------------------------------------------------------------
		singleton.game_system.Dialogue_Close()
	#-------------------------------------------------------------------------------
	else:
		await singleton.game_system.Dialogue_with_Face_0(_character_node.character_resource, \"* Querés que me vaya del grupo?\")
		singleton.game_system.Open_Dialogue_Options([\"Si\", \"No\"])
		await singleton.game_system.next_signal
		#-------------------------------------------------------------------------------
		match(singleton.game_system.dialogue_option_index):
			0:
				#-------------------------------------------------------------------------------
				if(singleton.game_system.ally_node_array.size() > 1):
					singleton.game_system.Close_Dialogue_Options()
					await singleton.game_system.Dialogue_with_Face(_character_node.character_resource, \"* Ok, voy a estar acá si me necesitas.\")
					singleton.game_system.ally_node_array[_index].queue_free()
					singleton.game_system.ally_node_array.remove_at(_index)
					singleton.game_system.Set_Fighter_0()
					_character_node.modulate.a = 1.0
				#-------------------------------------------------------------------------------
				else:
					singleton.game_system.Close_Dialogue_Options()
					await singleton.game_system.Dialogue_with_Face(_character_node.character_resource, \"* No podés tener cero aliados en tu equipo.\")
				#-------------------------------------------------------------------------------
			#-------------------------------------------------------------------------------
			1:
				singleton.game_system.Close_Dialogue_Options()
				await singleton.game_system.Dialogue_with_Face(_character_node.character_resource, \"* Ok, sigo con vos.\")
			#-------------------------------------------------------------------------------
		#-------------------------------------------------------------------------------
		singleton.game_system.Dialogue_Close()
	#-------------------------------------------------------------------------------
	_imteractable_script.collider.disabled = false
#-------------------------------------------------------------------------------
func NPC_3_Talk():
	npc_3.collider.disabled = true
	#-------------------------------------------------------------------------------
	var _game_system: Game_System = singleton.game_system
	var _player_1_character_resource: Character_Resource = _game_system.ally_node_array[0].character_node.character_resource
	_game_system.Stop_Moving()
	_game_system.Dialogue_Open()
	#-------------------------------------------------------------------------------
	await _game_system.Dialogue_with_Face_0(npc_3_character_resource, \"* Hola Che. Vamos a pelear!\")
	_game_system.Open_Dialogue_Options([\"Comprar\", \"Hablar\", \"Irse\"])
	await _game_system.next_signal
	#-------------------------------------------------------------------------------
	match(_game_system.dialogue_option_index):
		0:
			_game_system.Close_Dialogue_Options()
			#-------------------------------------------------------------------------------
			await _game_system.Dialogue_with_Face(_player_1_character_resource, \"* Quiero Comprar.\")
			await _game_system.Dialogue_with_Face(npc_3_character_resource, \"* Ok, te muestro lo que tengo.\")
			_game_system.Dialogue_Close_0()
			await _game_system.Open_Market(npc_3.name, npc_3_item_consumable_array, npc_3_item_equip_array, npc_3_item_key_array)
			#-------------------------------------------------------------------------------
			_game_system.Dialogue_Open()
			await _game_system.Dialogue_with_Face(npc_3_character_resource, \"* Gracias, vuelva Pronto.\")
		#-------------------------------------------------------------------------------
		1:
			_game_system.Close_Dialogue_Options()
			#-------------------------------------------------------------------------------
			await _game_system.Dialogue_with_Face(_player_1_character_resource, \"* Si. Bla bla bla bla bla bla bla bla bla bla bla bla bla.\")
			await _game_system.Dialogue_with_Face(npc_3_character_resource, \"* Ok, pero ya no tengo ganas, asique ya fué.\")
		#-------------------------------------------------------------------------------
		2:
			_game_system.Close_Dialogue_Options()
			#-------------------------------------------------------------------------------
			await _game_system.Dialogue_with_Face(_player_1_character_resource, \"* No. Bla bla bla bla bla bla bla bla bla bla bla bla bla.\")
			await _game_system.Dialogue_with_Face(npc_3_character_resource, \"* No? Ok, para la próxima.\")
		#-------------------------------------------------------------------------------
	#-------------------------------------------------------------------------------
	_game_system.Dialogue_Close()
	#-------------------------------------------------------------------------------
	npc_3.collider.disabled = false
#-------------------------------------------------------------------------------
func NPC_4_Talk():
	npc_4.collider.disabled = true
	#-------------------------------------------------------------------------------
	var _game_system: Game_System = singleton.game_system
	var _player_1_character_resource: Character_Resource = _game_system.ally_node_array[0].character_node.character_resource
	_game_system.Stop_Moving()
	_game_system.Dialogue_Open()
	#-------------------------------------------------------------------------------
	await _game_system.Dialogue_with_Face_0(npc_3_character_resource, \"* Hola Che. Vamos a pelear!\")
	_game_system.Open_Dialogue_Options([\"Pelear\", \"Irse\"])
	await _game_system.next_signal
	#-------------------------------------------------------------------------------
	match(_game_system.dialogue_option_index):
		0:
			_game_system.Close_Dialogue_Options()
			#-------------------------------------------------------------------------------
			await _game_system.Dialogue_with_Face(_player_1_character_resource, \"* Quiero Pelear.\")
			await _game_system.Dialogue_with_Face(npc_3_character_resource, \"* Ok, vamos a pelear.\")
			#-------------------------------------------------------------------------------
			_game_system.Dialogue_Close()
			_game_system.enemy_node_array = npc_4_fighter_array
			_game_system.Enter_Battle()
			await _game_system.next_signal
		#-------------------------------------------------------------------------------
		1:
			_game_system.Close_Dialogue_Options()
			#-------------------------------------------------------------------------------
			await _game_system.Dialogue_with_Face(_player_1_character_resource, \"* No.\")
			await _game_system.Dialogue_with_Face(npc_3_character_resource, \"* No? Ok, para la próxima.\")
		#-------------------------------------------------------------------------------
	#-------------------------------------------------------------------------------
	_game_system.Dialogue_Close()
	#-------------------------------------------------------------------------------
	npc_4.collider.disabled = false
#-------------------------------------------------------------------------------
"

